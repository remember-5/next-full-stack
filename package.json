    "lint-staged": "^16.4.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "7.6.0",
    "tailwindcss": "^4.0.15",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.27.0"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "bunx eslint --fix"
    ],
    "*.{js,jsx,ts,tsx,md,mdx,json,css,scss}": [
      "bunx prettier --write"
    ]
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  }
}
