# Copy this file to `.env.test` before running Playwright locally.

# Better Auth
BETTER_AUTH_URL="http://localhost:3001"
BETTER_AUTH_SECRET=""
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-now"
ADMIN_NAME="Initial Admin"

# Local PostgreSQL shared instance for test schema isolation
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="next-full-stack"
POSTGRES_PORT="5432"

# Prisma
DATABASE_URL="postgresql://postgres:password@localhost:5432/next-full-stack?schema=e2e"
